%% B. 模式分配 (仅影响特殊页)
\ifSU@dark
    \def\SUwatermarkOlive{logo/watermark_olive_white.png}
    \def\SUwatermarkFlame{logo/watermark_flame_white.png}
    \def\SUwmOpacity{0.15}   % 白色在深蓝底上需要高一点透明度
    \def\SUspBgColor{SUblue} % 特殊页背景色
    \def\SUspFgColor{white}  % 特殊页主标题色
    \def\SUspSubColor{SUsky} % 特殊页副信息色
\else
    \def\SUwatermarkOlive{logo/watermark_olive_blue.png}
    \def\SUwatermarkFlame{logo/watermark_flame_blue.png}
    \def\SUwmOpacity{0.05}   % 蓝色在白底上必须压低透明度
    \def\SUspBgColor{white}  
    \def\SUspFgColor{SUblue} 
    \def\SUspSubColor{SUgrey}
