%% ==========================================
%% 3. 智能分配资源与色彩变数 (核心逻辑)
%% ==========================================
%% A. 语言分配
\ifSU@english
    \def\SUnormalLogo{logo/su_vert_en_blue.png} % 普通页雷打不动的蓝标
